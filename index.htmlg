<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>KODE</title>

<style>
*{margin:0;padding:0;box-sizing:border-box}

:root{
--rojo:#ff1e2d;
--verde:#00ff9f;
--bg:#020202;
}

body{
min-height:100vh;
font-family:Arial;
background:#000;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
overflow:hidden;
}

/* 🔥 FONDO HACKER */
.bg{
position:fixed;
inset:0;
background:
radial-gradient(circle at 50% 50%, rgba(0,255,150,.08), transparent 60%),
linear-gradient(#000,#000),
url("https://images.unsplash.com/photo-1515879218367-8466d910aaa4?q=80&w=1974&auto=format&fit=crop") center/cover;
opacity:.4;
z-index:0;
}

/* 🔥 PANEL */
.wrap{
position:relative;
z-index:2;
width:min(92%,700px);
text-align:center;
padding:40px;
border-radius:20px;
background:rgba(0,0,0,.7);
border:1px solid rgba(0,255,150,.2);
backdrop-filter:blur(10px);
box-shadow:0 0 60px rgba(0,255,150,.08);
}

/* 🔥 TITULO */
.title{
font-size:clamp(3rem,10vw,6rem);
font-weight:900;
letter-spacing:6px;
color:#fff;
text-shadow:0 0 15px rgba(0,255,150,.3);
}

/* 🔥 PROGRESO */
.meta-line{margin-top:20px;font-size:1.4rem;font-weight:800}
.votes-line{margin-top:10px;color:#aaa}

.bar{
width:100%;
height:22px;
margin-top:20px;
border-radius:999px;
background:rgba(255,255,255,.05);
border:1px solid rgba(0,255,150,.2);
overflow:hidden;
}

.fill{
height:100%;
width:0%;
background:linear-gradient(90deg,var(--verde),#fff);
box-shadow:0 0 15px var(--verde);
transition:.4s;
}

/* 🔥 BOTÓN */
.btn{
margin-top:25px;
padding:15px 30px;
border:none;
border-radius:12px;
background:linear-gradient(180deg,var(--rojo),#a80f1a);
color:#fff;
font-weight:900;
cursor:pointer;
box-shadow:0 0 20px rgba(255,0,0,.3);
transition:.2s;
}

.btn:hover{
transform:translateY(-2px);
}

.msg{
margin-top:12px;
font-weight:700;
}

/* 🔥 AVATAR */
#avatarOverlay{
position:fixed;
inset:0;
background:rgba(0,0,0,.9);
display:none;
z-index:999999;
}

#avatarOverlay.active{
display:block;
}

.avatar-container{
position:absolute;
bottom:40px;
left:40px;
display:flex;
align-items:center;
gap:20px;
}

.avatar-container img{
width:260px;
image-rendering:pixelated;
filter:drop-shadow(0 20px 30px rgba(0,0,0,.7));
}

.speech-bubble{
background:#fff;
color:#000;
padding:16px 20px;
border-radius:25px;
font-weight:900;
max-width:340px;
opacity:0;
transform:scale(.7);
}

.speech-bubble.show{
opacity:1;
transform:scale(1);
transition:.3s;
}

/* 🔥 COUNTDOWN */
#countdownPopup{
position:fixed;
inset:0;
display:none;
align-items:center;
justify-content:center;
background:rgba(0,0,0,.9);
z-index:999998;
}

#countdownPopup.active{display:flex}

.countdown-time{
font-size:4rem;
font-weight:900;
color:var(--verde);
text-shadow:0 0 20px var(--verde);
}
</style>
</head>

<body>

<div class="bg"></div>

<div class="wrap">
<h1 class="title">KODE</h1>

<div id="metaLine">0/15</div>
<div id="votesLine">0 votos</div>

<div class="bar">
<div id="fill" class="fill"></div>
</div>

<button id="btn" class="btn">CLICK</button>
<div id="msg" class="msg"></div>
</div>

<!-- AVATAR -->
<div id="avatarOverlay">
<div class="avatar-container">
<img src="assets/1.png">
<div class="speech-bubble" id="speechBubble">
<span id="speechText"></span>
</div>
</div>
</div>

<!-- COUNTDOWN -->
<div id="countdownPopup">
<div class="countdown-time" id="countdownTime">10:00</div>
</div>

<script type="module">
import { initializeApp, getApps, getApp } from "https://www.gstatic.com/firebasejs/10.12.5/firebase-app.js";
import { getFirestore, doc, runTransaction, onSnapshot } from "https://www.gstatic.com/firebasejs/10.12.5/firebase-firestore.js";

const firebaseConfig={
apiKey:"AIzaSyB...",
authDomain:"gorflacos.firebaseapp.com",
projectId:"gorflacos"
};

const app=getApps().length?getApp():initializeApp(firebaseConfig);
const db=getFirestore(app);

const progressRef=doc(db,"progress","kode_main");
const announcementRef=doc(db,"system","globalAnnouncement");

const btn=document.getElementById("btn");
const msg=document.getElementById("msg");
const fill=document.getElementById("fill");
const metaLine=document.getElementById("metaLine");
const votesLine=document.getElementById("votesLine");

const avatarOverlay=document.getElementById("avatarOverlay");
const speechBubble=document.getElementById("speechBubble");
const speechText=document.getElementById("speechText");

const countdownPopup=document.getElementById("countdownPopup");
const countdownTime=document.getElementById("countdownTime");

const LOCAL_KEY="kode_voted";

let typingInterval;
let countdownInterval;

/* BLOQUEO */
function lock(){
btn.disabled=true;
btn.style.opacity=".5";
msg.textContent="Ya votaste";
}

/* INICIO */
if(localStorage.getItem(LOCAL_KEY)) lock();

/* CLICK */
btn.onclick=async()=>{
if(localStorage.getItem(LOCAL_KEY)) return;

lock();
msg.textContent="Enviando...";

await runTransaction(db, async (t)=>{
const snap=await t.get(progressRef);
let c=snap.data().current||0;
c++;
t.set(progressRef,{current:c},{merge:true});
});

localStorage.setItem(LOCAL_KEY,"1");
msg.textContent="Voto registrado";
};

/* PROGRESO */
onSnapshot(progressRef,snap=>{
const d=snap.data()||{};
const c=d.current||0;
const t=d.total||15;

metaLine.textContent=`${c}/${t}`;
votesLine.textContent=`${c} votos`;
fill.style.width=`${(c/t)*100}%`;

if(localStorage.getItem(LOCAL_KEY)) lock();

if(d.countdownActive && d.countdownEndsAt){
startCountdown(d.countdownEndsAt);
}else{
countdownPopup.classList.remove("active");
}
});

/* COUNTDOWN */
function startCountdown(endAt){
countdownPopup.classList.add("active");

if(countdownInterval) clearInterval(countdownInterval);

const tick=()=>{
const r=endAt-Date.now();

if(r<=0){
countdownTime.textContent="00:00";
clearInterval(countdownInterval);
setTimeout(()=>countdownPopup.classList.remove("active"),800);
return;
}

const s=Math.floor(r/1000);
const m=Math.floor(s/60);
const sec=s%60;

countdownTime.textContent=`${String(m).padStart(2,"0")}:${String(sec).padStart(2,"0")}`;
};

tick();
countdownInterval=setInterval(tick,1000);
}

/* AVATAR TEXTO */
function typeText(text){
clearInterval(typingInterval);
speechText.textContent="";
let i=0;

typingInterval=setInterval(()=>{
speechText.textContent+=text[i];
i++;
if(i>=text.length) clearInterval(typingInterval);
},30);
}

function showAnnouncement(text){
avatarOverlay.classList.add("active");
speechBubble.classList.remove("show");

setTimeout(()=>{
speechBubble.classList.add("show");
typeText(text);
},300);
}

function hideAnnouncement(){
avatarOverlay.classList.remove("active");
}

/* FIREBASE */
onSnapshot(announcementRef,snap=>{
const d=snap.data()||{};
if(d.active && d.text){
showAnnouncement(d.text);
}else{
hideAnnouncement();
}
});
</script>

</body>
</html>
